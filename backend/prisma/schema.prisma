generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// USUARIOS
// ─────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  cognitoId String   @unique
  email     String   @unique
  name      String
  role      Role     @default(STUDENT)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userPaths             UserPath[]
  submissions           Submission[]
  careerRecommendations CareerRecommendation[]
  careerRoadmaps        CareerRoadmap[]

  @@index([email])
  @@index([cognitoId])
  @@map("users")
}

enum Role {
  STUDENT
  ADMIN
}

// ─────────────────────────────────────────
// MATERIAS (JavaScript, Python, AWS, etc...)
// ─────────────────────────────────────────

model Subject {
  id          String  @id @default(uuid())
  name        String  @unique
  slug        String  @unique
  description String?
  iconUrl     String?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  challenges    Challenge[]
  pathTemplates PathTemplate[]
  concepts      Concept[]

  @@index([slug])
  @@map("subjects")
}

// ─────────────────────────────────────────
// RETOS (ejercicios de código de programación primer mvp)
// ─────────────────────────────────────────

model Challenge {
  id          String     @id @default(uuid())
  title       String
  slug        String     @unique
  description String
  difficulty  Difficulty
  points      Int
  timeLimit   Int        // segundos
  memoryLimit Int        // MB
  isActive    Boolean    @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id])

  testCases   TestCase[]
  submissions Submission[]
  moduleItems ModuleItem[]

  @@index([subjectId])
  @@index([difficulty])
  @@map("challenges")
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model TestCase {
  id         String  @id @default(uuid())
  input      String
  expected   String
  isPublic   Boolean @default(false)
  orderIndex Int

  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id])

  @@unique([challengeId, orderIndex])
  @@index([challengeId])
  @@map("test_cases")
}

// ─────────────────────────────────────────
// RUTAS DE APRENDIZAJE — PLANTILLAS
// ─────────────────────────────────────────

model PathTemplate {
  id          String  @id @default(uuid())
  title       String
  slug        String  @unique
  description String
  level       Level
  goal        String
  weeklyHours Int
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id])

  modules            PathModule[]
  userPaths          UserPath[]
  careerRoadmapSteps CareerRoadmapStep[]

  @@index([subjectId])
  @@index([level])
  @@map("path_templates")
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model PathModule {
  id           String  @id @default(uuid())
  title        String
  description  String?
  orderIndex   Int
  durationDays Int

  pathTemplateId String
  pathTemplate   PathTemplate @relation(fields: [pathTemplateId], references: [id])

  items    ModuleItem[]
  progress ModuleProgress[]
  concepts ConceptOnModule[]

  @@unique([pathTemplateId, orderIndex])
  @@map("path_modules")
}

// Relación entre módulos y retos
model ModuleItem {
  id         String @id @default(uuid())
  orderIndex Int

  moduleId String
  module   PathModule @relation(fields: [moduleId], references: [id])

  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id])

  @@unique([moduleId, challengeId])
  @@index([moduleId])
  @@map("module_items")
}

model Concept {
  id        String @id @default(uuid())
  name      String
  slug      String @unique
  level     Level
  subjectId String
  subject   Subject         @relation(fields: [subjectId], references: [id])
  moduleItems ConceptOnModule[]

  @@index([subjectId])
  @@index([level])
  @@map("concepts")
}

model ConceptOnModule {
  moduleId  String
  conceptId String
  module    PathModule @relation(fields: [moduleId], references: [id])
  concept   Concept    @relation(fields: [conceptId], references: [id])

  @@id([moduleId, conceptId])
  @@map("concept_on_modules")
}

// ─────────────────────────────────────────
// RUTAS DE APRENDIZAJE — INSTANCIA USUARIO
// ─────────────────────────────────────────

model UserPath {
  id           String     @id @default(uuid())
  status       PathStatus @default(ACTIVE)
  currentLevel String?
  goal         String
  weeklyHours  Int
  isCustom     Boolean    @default(false)
  customTitle  String?
  startedAt    DateTime   @default(now())
  completedAt  DateTime?
  updatedAt    DateTime   @updatedAt

  userId         String
  pathTemplateId String?
  user           User          @relation(fields: [userId], references: [id])
  pathTemplate   PathTemplate? @relation(fields: [pathTemplateId], references: [id])

  moduleProgress     ModuleProgress[]
  careerRoadmapSteps CareerRoadmapStep[]

  @@index([userId])
  @@map("user_paths")
}

enum PathStatus {
  ACTIVE
  COMPLETED
  PAUSED
  ABANDONED
}

model ModuleProgress {
  id          String       @id @default(uuid())
  status      ModuleStatus @default(PENDING)
  completedAt DateTime?

  userPathId String
  userPath   UserPath @relation(fields: [userPathId], references: [id])

  moduleId String
  module   PathModule @relation(fields: [moduleId], references: [id])

  @@unique([userPathId, moduleId])
  @@index([userPathId])
  @@map("module_progress")
}

enum ModuleStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

// ─────────────────────────────────────────
// SUBMISSIONS (intentos de retos)
// ─────────────────────────────────────────

model Submission {
  id           String           @id @default(uuid())
  code         String
  language     String
  status       SubmissionStatus @default(PENDING)
  executionMs  Int?
  memoryUsedMb Int?
  passedTests  Int              @default(0)
  totalTests   Int              @default(0)
  errorMessage String?
  s3LogKey     String?

  submittedAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id])

  @@index([userId])
  @@index([challengeId])
  @@index([status])
  @@map("submissions")
}

enum SubmissionStatus {
  PENDING
  RUNNING
  ACCEPTED
  WRONG_ANSWER
  TIME_LIMIT_EXCEEDED
  MEMORY_LIMIT_EXCEEDED
  RUNTIME_ERROR
  COMPILATION_ERROR
}

// ─────────────────────────────────────────
// CAREER DISCOVERY
// ─────────────────────────────────────────

model CareerRecommendation {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  recommendations Json
  userProfile     Json
  createdAt       DateTime @default(now())

  careerRoadmaps CareerRoadmap[]

  @@index([userId])
  @@map("career_recommendations")
}

// ─────────────────────────────────────────
// CAREER ROADMAP
// ─────────────────────────────────────────

model CareerRoadmap {
  id                     String        @id @default(uuid())
  userId                 String
  careerSlug             String
  careerTitle            String
  status                 RoadmapStatus @default(ACTIVE)
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  careerRecommendationId String
  user                   User          @relation(fields: [userId], references: [id])
  careerRecommendation   CareerRecommendation @relation(fields: [careerRecommendationId], references: [id])
  steps                  CareerRoadmapStep[]
  @@index([userId])
  @@index([careerRecommendationId])
  @@map("career_roadmaps")
}

enum RoadmapStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

model CareerRoadmapStep {
  id        String     @id @default(uuid())
  techSlug  String
  techLabel String
  order     Int
  status    StepStatus @default(LOCKED)

  roadmapId      String
  pathTemplateId String?
  userPathId     String?

  roadmap      CareerRoadmap  @relation(fields: [roadmapId], references: [id])
  pathTemplate PathTemplate?  @relation(fields: [pathTemplateId], references: [id])
  userPath     UserPath?      @relation(fields: [userPathId], references: [id])

  @@unique([roadmapId, order])
  @@index([roadmapId])
  @@index([userPathId])
  @@map("career_roadmap_steps")
}

enum StepStatus {
  LOCKED
  AVAILABLE
  IN_PROGRESS
  COMPLETED
}

